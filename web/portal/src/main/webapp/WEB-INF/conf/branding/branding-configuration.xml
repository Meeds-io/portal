<configuration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://www.exoplatform.org/xml/ns/kernel_1_2.xsd http://www.exoplatform.org/xml/ns/kernel_1_2.xsd"
               xmlns="http://www.exoplatform.org/xml/ns/kernel_1_2.xsd">
  <component>
    <key>org.exoplatform.portal.branding.BrandingService</key>
    <type>org.exoplatform.portal.branding.BrandingServiceImpl</type>
    <init-params>
      <value-param>
        <name>exo.branding.company.name</name>
        <value>${exo.branding.company.name:Web3 Hub}</value>
      </value-param>
      <value-param>
        <name>exo.branding.company.siteName</name>
        <value>${exo.branding.company.siteName:Meeds}</value>
      </value-param>
      <value-param>
        <name>exo.branding.company.link</name>
        <value>${exo.branding.company.link:https://meeds.io}</value>
      </value-param>
      <value-param>
        <name>exo.branding.company.logo</name>
        <value>${exo.branding.company.logo:/skin/images/logo/DefaultLogo.png}</value>
      </value-param>
      <value-param>
        <name>exo.branding.company.favicon</name>
        <value>${exo.branding.company.favicon:/skin/images/favicon.ico}</value>
      </value-param>
      <value-param>
        <name>authentication.background</name>
        <value>${portal.authentication.background:}</value>
      </value-param>
      <value-param>
        <name>authentication.title</name>
        <value>${portal.authentication.title:UILoginForm.label.pageTitle}</value>
      </value-param>
      <value-param>
        <name>authentication.subtitle</name>
        <value>${portal.authentication.subtitle:UILoginForm.label.pageSubTitle}</value>
      </value-param>
      <value-param>
        <name>exo.branding.theme.path</name>
        <value>${exo.branding.theme.path:war:/conf/branding/branding.less}</value>
      </value-param>
      <values-param>
        <name>exo.branding.theme.variables</name>
        <value>${exo.branding.theme.primaryColor:primaryColor:#3f8487}</value>
        <value>${exo.branding.theme.secondaryColor:secondaryColor:#e25d5d}</value>
        <value>${exo.branding.theme.tertiaryColor:tertiaryColor:#e25d5d}</value>
        <value>${exo.branding.theme.greyColorLighten1:greyColorLighten1:#707070}</value>
        <value>${exo.branding.theme.textColor:textColor:#20282c}</value>
        <value>${exo.branding.theme.borderRadius:borderRadius:8px}</value>

        <value>${exo.branding.theme.topBarTextColor:topBarTextColor:#20282c}</value>
        <value>${exo.branding.theme.topBarTextFontSize:topBarTextFontSize:16px}</value>
        <value>${exo.branding.theme.topBarTextFontStyle:topBarTextFontStyle:normal}</value>
        <value>${exo.branding.theme.topBarTextFontWeight:topBarTextFontWeight:normal}</value>
        <value>${exo.branding.theme.topBarBackgroundColor:topBarBackgroundColor:#FFFFFFFF}</value>
        <value>${exo.branding.theme.topBarBackgroundPosition:topBarBackgroundPosition:left top}</value>
        <value>${exo.branding.theme.topBarBackgroundSize:topBarBackgroundSize:cover}</value>
        <value>${exo.branding.theme.topBarBackgroundImage:topBarBackgroundImage:none}</value>
        <value>${exo.branding.theme.topBarBackgroundRepeat:topBarBackgroundRepeat:no-repeat}</value>

        <value>${exo.branding.theme.sideBarTextColor:sideBarTextColor:#20282c}</value>
        <value>${exo.branding.theme.sideBarTextFontSize:sideBarTextFontSize:16px}</value>
        <value>${exo.branding.theme.sideBarTextFontStyle:sideBarTextFontStyle:normal}</value>
        <value>${exo.branding.theme.sideBarTextFontWeight:sideBarTextFontWeight:normal}</value>
        <value>${exo.branding.theme.sideBarTextSubtitleColor:sideBarTextSubtitleColor:#707070}</value>
        <value>${exo.branding.theme.sideBarTextSubtitleFontSize:sideBarTextSubtitleFontSize:12px}</value>
        <value>${exo.branding.theme.sideBarTextSubtitleFontStyle:sideBarTextSubtitleFontStyle:normal}</value>
        <value>${exo.branding.theme.sideBarTextSubtitleFontWeight:sideBarTextSubtitleFontWeight:normal}</value>
        <value>${exo.branding.theme.sideBarBackgroundColor:sideBarBackgroundColor:#FFFFFFFF}</value>
        <value>${exo.branding.theme.sideBarBackgroundPosition:sideBarBackgroundPosition:left top}</value>
        <value>${exo.branding.theme.sideBarBackgroundSize:sideBarBackgroundSize:cover}</value>
        <value>${exo.branding.theme.sideBarBackgroundImage:sideBarBackgroundImage:none}</value>
        <value>${exo.branding.theme.sideBarBackgroundRepeat:sideBarBackgroundRepeat:no-repeat}</value>

        <value>${exo.branding.theme.drawerTextTitleColor:drawerTextTitleColor:#20282c}</value>
        <value>${exo.branding.theme.drawerTextTitleFontSize:drawerTextTitleFontSize:20px}</value>
        <value>${exo.branding.theme.drawerTextTitleFontStyle:drawerTextTitleFontStyle:normal}</value>
        <value>${exo.branding.theme.drawerTextTitleFontWeight:drawerTextTitleFontWeight:bold}</value>
        <value>${exo.branding.theme.drawerTextHeaderColor:drawerTextHeaderColor:#707070}</value>
        <value>${exo.branding.theme.drawerTextHeaderFontSize:drawerTextHeaderFontSize:18px}</value>
        <value>${exo.branding.theme.drawerTextHeaderFontStyle:drawerTextHeaderFontStyle:normal}</value>
        <value>${exo.branding.theme.drawerTextHeaderFontWeight:drawerTextHeaderFontWeight:normal}</value>
        <value>${exo.branding.theme.drawerTextColor:drawerTextColor:#20282c}</value>
        <value>${exo.branding.theme.drawerTextFontSize:drawerTextFontSize:16px}</value>
        <value>${exo.branding.theme.drawerTextFontStyle:drawerTextFontStyle:normal}</value>
        <value>${exo.branding.theme.drawerTextFontWeight:drawerTextFontWeight:normal}</value>
        <value>${exo.branding.theme.drawerTextSubtitleColor:drawerTextSubtitleColor:#707070}</value>
        <value>${exo.branding.theme.drawerTextSubtitleFontSize:drawerTextSubtitleFontSize:12px}</value>
        <value>${exo.branding.theme.drawerTextSubtitleFontStyle:drawerTextSubtitleFontStyle:normal}</value>
        <value>${exo.branding.theme.drawerTextSubtitleFontWeight:drawerTextSubtitleFontWeight:normal}</value>
        <value>${exo.branding.theme.drawerBackgroundColor:drawerBackgroundColor:#FFFFFFFF}</value>
        <value>${exo.branding.theme.drawerBackgroundPosition:drawerBackgroundPosition:left top}</value>
        <value>${exo.branding.theme.drawerBackgroundSize:drawerBackgroundSize:cover}</value>
        <value>${exo.branding.theme.drawerBackgroundImage:drawerBackgroundImage:none}</value>
        <value>${exo.branding.theme.drawerBackgroundRepeat:drawerBackgroundRepeat:no-repeat}</value>
      </values-param>
    </init-params>
  </component>

  <component>
    <type>org.exoplatform.portal.branding.BrandingRestResourcesV1</type>
  </component>

  <external-component-plugins>
    <target-component>org.exoplatform.commons.file.services.NameSpaceService</target-component>
    <component-plugin>
      <name>BrandingNameSpacePlugin</name>
      <set-method>addNameSpacePlugin</set-method>
      <type>org.exoplatform.commons.file.services.NameSpacePlugin</type>
      <init-params>
        <properties-param>
          <name>fileNameSpace.params</name>
          <property name="name" value="CompanyBranding"/>
          <property name="description" value="Company Branding files storage"/>
        </properties-param>
      </init-params>
    </component-plugin>
  </external-component-plugins>
</configuration>
