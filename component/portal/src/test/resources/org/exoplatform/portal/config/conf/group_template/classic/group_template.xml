<portal-config
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.gatein.org/xml/ns/gatein_objects_1_10 http://www.gatein.org/xml/ns/gatein_objects_1_10"
    xmlns="http://www.gatein.org/xml/ns/gatein_objects_1_10">
  <portal-name>classic</portal-name>
  <label>Classic Label</label>
  <description>Classic Description</description>
  <display-order>1</display-order>
  <displayed>false</displayed>
  <locale>en</locale>
  <access-permissions>member:@owner_id@</access-permissions>
  <edit-permission>manager:@owner_id@</edit-permission>
  <portal-layout>
    <portlet-application>
      <portlet>
        <application-ref>test</application-ref>
        <portlet-ref>app</portlet-ref>
        <preferences>
          <preference>
            <name>preference1</name>
            <value>preferenceValue1</value>
          </preference>
        </preferences>
      </portlet>
      <access-permissions>member:@owner_id@</access-permissions>
      <show-info-bar>false</show-info-bar>
    </portlet-application>
    <page-body></page-body>
  </portal-layout>
</portal-config>
